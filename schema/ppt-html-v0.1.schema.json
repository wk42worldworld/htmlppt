{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wk42worldworld/htmlppt/schema/ppt-html-v0.1.schema.json",
  "title": "PPT.html Deck v0.1",
  "type": "object",
  "required": ["version", "title", "slides"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "string",
      "enum": ["paper", "launch", "studio", "boardroom"],
      "default": "paper"
    },
    "transition": {
      "$ref": "#/$defs/transition"
    },
    "aspectRatio": {
      "type": "string",
      "enum": ["16:9"],
      "default": "16:9"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slide"
      }
    }
  },
  "$defs": {
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "src": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "fit": {
          "type": "string",
          "enum": ["cover", "contain"],
          "default": "cover"
        }
      }
    },
    "video": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "src": {
          "type": "string"
        },
        "poster": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "fit": {
          "type": "string",
          "enum": ["cover", "contain"],
          "default": "cover"
        },
        "controls": {
          "type": "boolean",
          "default": true
        },
        "autoplay": {
          "type": "boolean",
          "default": false
        },
        "loop": {
          "type": "boolean",
          "default": false
        },
        "muted": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "src": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "controls": {
          "type": "boolean",
          "default": true
        },
        "autoplay": {
          "type": "boolean",
          "default": false
        },
        "loop": {
          "type": "boolean",
          "default": false
        },
        "muted": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "textPair": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "value": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "chartSeries": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["bar", "line", "donut"],
          "default": "bar"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "series": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chartSeries"
          }
        },
        "unit": {
          "type": "string"
        }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "textBox": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "w": {
          "type": "number"
        },
        "h": {
          "type": "number"
        }
      }
    },
    "shape": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["rectangle", "roundedRectangle", "ellipse", "line", "arrow", "callout"],
          "default": "rectangle"
        },
        "text": {
          "type": "string"
        },
        "fill": {
          "type": "string"
        },
        "stroke": {
          "type": "string"
        },
        "strokeWidth": {
          "type": "number",
          "minimum": 0,
          "maximum": 48
        }
      }
    },
    "slideObject": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["image", "video", "audio", "chart", "table", "cards", "metrics", "timeline", "quote", "code", "compare", "shape"]
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "w": {
          "type": "number"
        },
        "h": {
          "type": "number"
        },
        "rotation": {
          "type": "number"
        },
        "zIndex": {
          "type": "number"
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        },
        "style": {
          "$ref": "#/$defs/styleOverride"
        }
      }
    },
    "transition": {
      "type": "string",
      "enum": ["none", "fade", "slide", "push", "zoom"],
      "default": "fade"
    },
    "slideTransition": {
      "type": "string",
      "enum": ["inherit", "none", "fade", "slide", "push", "zoom"],
      "default": "inherit"
    },
    "canvasOffset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "w": {
          "type": "number"
        },
        "h": {
          "type": "number"
        }
      }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/canvasOffset"
      }
    },
    "styleOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fontFamily": {
          "type": "string",
          "enum": [
            "system",
            "display",
            "arial",
            "helvetica",
            "aptos",
            "calibri",
            "verdana",
            "tahoma",
            "avenir",
            "serif",
            "georgia",
            "times",
            "cambria",
            "cjk-sans",
            "pingfang",
            "yahei",
            "dengxian",
            "simhei",
            "stheiti",
            "hiragino-sans",
            "noto-sans-cjk",
            "cjk-serif",
            "songti",
            "simsun",
            "fangsong",
            "kaiti",
            "yu-mincho",
            "noto-serif-cjk",
            "yu-gothic",
            "meiryo",
            "malgun",
            "mono",
            "menlo",
            "consolas",
            "courier",
            "handwriting"
          ]
        },
        "fontSize": {
          "type": "number",
          "minimum": 8,
          "maximum": 180
        },
        "color": {
          "$ref": "#/$defs/styleColor"
        },
        "backgroundColor": {
          "$ref": "#/$defs/styleColor"
        },
        "borderColor": {
          "$ref": "#/$defs/styleColor"
        },
        "borderWidth": {
          "type": "number",
          "minimum": 0,
          "maximum": 24
        },
        "borderRadius": {
          "type": "number",
          "minimum": 0,
          "maximum": 96
        },
        "opacity": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 1
        },
        "textAlign": {
          "type": "string",
          "enum": ["left", "center", "right", "justify"]
        },
        "fontWeight": {
          "type": "string",
          "enum": ["400", "500", "600", "700", "800", "900"]
        },
        "fontStyle": {
          "type": "string",
          "enum": ["italic"]
        }
      }
    },
    "styleColor": {
      "type": "string",
      "pattern": "^(#([0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})|rgba?\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}(\\s*,\\s*(0|1|0?\\.\\d+))?\\s*\\))$"
    },
    "styles": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/styleOverride"
      }
    },
    "slide": {
      "type": "object",
      "required": ["layout", "title"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "layout": {
          "type": "string",
          "enum": [
            "hero",
            "section",
            "text",
            "imageRight",
            "imageLeft",
            "imageFull",
            "imageBackground",
            "compare",
            "threeCards",
            "quote",
            "timeline",
            "data",
            "chart",
            "video",
            "audio",
            "table",
            "code",
            "ending"
          ]
        },
        "transition": {
          "$ref": "#/$defs/slideTransition"
        },
        "kicker": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "image": {
          "$ref": "#/$defs/image"
        },
        "video": {
          "$ref": "#/$defs/video"
        },
        "audio": {
          "$ref": "#/$defs/audio"
        },
        "textBoxes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/textBox"
          }
        },
        "objects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/slideObject"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/textPair"
              }
            ]
          }
        },
        "cards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/textPair"
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "chart": {
          "$ref": "#/$defs/chart"
        },
        "left": {
          "$ref": "#/$defs/textPair"
        },
        "right": {
          "$ref": "#/$defs/textPair"
        },
        "table": {
          "$ref": "#/$defs/table"
        },
        "quote": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "canvas": {
          "$ref": "#/$defs/canvas"
        },
        "styles": {
          "$ref": "#/$defs/styles"
        }
      }
    }
  }
}
