{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wk42worldworld/htmlppt/schema/ppt-html-v0.1.schema.json",
  "title": "PPT.html Deck v0.1",
  "type": "object",
  "required": ["version", "title", "slides"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "string",
      "enum": ["paper", "launch", "studio", "boardroom"],
      "default": "paper"
    },
    "aspectRatio": {
      "type": "string",
      "enum": ["16:9"],
      "default": "16:9"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slide"
      }
    }
  },
  "$defs": {
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "src": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "fit": {
          "type": "string",
          "enum": ["cover", "contain"],
          "default": "cover"
        }
      }
    },
    "textPair": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "value": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "chartSeries": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "chart": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["bar", "line", "donut"],
          "default": "bar"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "series": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chartSeries"
          }
        },
        "unit": {
          "type": "string"
        }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "slide": {
      "type": "object",
      "required": ["layout", "title"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "layout": {
          "type": "string",
          "enum": [
            "hero",
            "section",
            "text",
            "imageRight",
            "imageLeft",
            "imageFull",
            "imageBackground",
            "compare",
            "threeCards",
            "quote",
            "timeline",
            "data",
            "chart",
            "table",
            "code",
            "ending"
          ]
        },
        "kicker": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "image": {
          "$ref": "#/$defs/image"
        },
        "items": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/textPair"
              }
            ]
          }
        },
        "cards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/textPair"
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "chart": {
          "$ref": "#/$defs/chart"
        },
        "left": {
          "$ref": "#/$defs/textPair"
        },
        "right": {
          "$ref": "#/$defs/textPair"
        },
        "table": {
          "$ref": "#/$defs/table"
        },
        "quote": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
